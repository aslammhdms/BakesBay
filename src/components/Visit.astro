---
const branches = [
  {
    tag: 'Main Branch',
    name: 'Maruthamalai Main Road',
    area: 'Vadavalli, Coimbatore',
    mapsQuery: 'Bakes+Bay+Maruthamalai+Road+Vadavalli+Coimbatore',
  },
  {
    tag: 'Branch II',
    name: 'Siruvani Road Junction',
    area: 'Vadavalli, Coimbatore',
    mapsQuery: 'Bakes+Bay+Siruvani+Road+Vadavalli+Coimbatore',
  },
  {
    tag: 'Branch III',
    name: 'Grand Bei Market',
    area: 'Opp. JC Bus Station, Vadavalli, Coimbatore',
    mapsQuery: 'Bakes+Bay+Grand+Bei+Market+Vadavalli+Coimbatore',
  },
  {
    tag: 'Branch IV',
    name: 'Thondamuthur Main Road',
    area: 'Near PSG School, Vedapatti, Coimbatore',
    mapsQuery: 'Bakes+Bay+Thondamuthur+Vedapatti+Coimbatore',
  },
];
---

<section id="visit" class="relative" data-section="visit">
  <div class="flex flex-col md:flex-row min-h-[80vh]">
    <div class="w-full md:w-1/2 min-h-[400px] md:min-h-0 relative bg-cream overflow-hidden">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3916.2!2d76.94!3d11.02!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTHCsDAxJzEyLjAiTiA3NsKwNTYnMjQuMCJF!5e0!3m2!1sen!2sin!4v1"
        class="w-full h-full absolute inset-0 border-0 sepia-[0.3] saturate-[0.7] opacity-85"
        allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
        title="Bakes Bay locations in Coimbatore"
      ></iframe>
    </div>

    <div class="w-full md:w-1/2 flex flex-col justify-center px-6 md:px-16 lg:px-24 py-16 md:py-24 bg-cream texture-paper">
      <span class="text-label text-sage mb-4 block">08 — Visit</span>
      <h2 class="text-display-md text-cocoa mb-2">Four Corners</h2>
      <p class="text-script text-lg text-caramel mb-10">four places to find us ↓</p>

      <div class="space-y-6 md:space-y-7">
        {branches.map((b) => (
          <a
            href={`https://maps.google.com/?q=${b.mapsQuery}`}
            target="_blank"
            rel="noopener noreferrer"
            class="branch-card group block border-b border-caramel/15 pb-5 hover:border-sage transition-colors duration-300"
          >
            <p class="text-label text-caramel/60 mb-1">{b.tag}</p>
            <p class="font-display text-xl md:text-2xl italic font-medium text-cocoa group-hover:text-sage transition-colors duration-300">
              {b.name}
            </p>
            <p class="text-sm md:text-base text-espresso/60 mt-1">{b.area}</p>
            <p class="text-script text-base text-caramel/70 mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              Get Directions ↗
            </p>
          </a>
        ))}
      </div>

      <div class="mt-10 pt-8 border-t border-caramel/15 space-y-3">
        <p class="text-label text-caramel/60">Hours</p>
        <p class="font-display text-lg italic font-medium text-cocoa">Everyday, 11am — 11pm</p>
      </div>
    </div>
  </div>
</section>
