---
const images = [
  { src: 'https://images.unsplash.com/photo-1567206563064-6f60f40a2b57?w=600&q=80', caption: 'Royal Falooda · friday vibes', tilt: 'tilt-left' },
  { src: 'https://images.unsplash.com/photo-1509440159596-0249088772ff?w=600&auto=format&q=80', caption: 'fresh from the oven ✨', tilt: 'tilt-right' },
  { src: 'https://images.unsplash.com/photo-1551538827-9c037cb4f32a?w=600&q=80', caption: 'Green Apple Mojito', tilt: '' },
  { src: 'https://images.unsplash.com/photo-1578985545062-69928b1d9587?w=600&q=80', caption: 'Dutch Truffle · always a hit', tilt: 'tilt-left' },
  { src: 'https://images.unsplash.com/photo-1486427944299-d1955d23e34d?w=600&q=80', caption: 'butter croissants · warm', tilt: 'tilt-right' },
  { src: 'https://images.unsplash.com/photo-1488477181946-6428a0291777?w=600&q=80', caption: 'Mango Lassi · summer fav', tilt: '' },
];
---

<section id="gallery" class="relative py-24 md:py-40 px-6 md:px-12 bg-cream" data-section="gallery">
  <!-- Section Header -->
  <div class="mb-16 md:mb-24">
    <span class="text-label text-sage mb-6 block">04 — Gallery</span>
    <h2 class="text-display-lg text-forest">The Craft</h2>
    <p class="text-script text-xl text-caramel mt-2">a peek behind the counter</p>
  </div>

  <!-- Pinboard-style Collage -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10">
    {images.map((img) => (
      <div class={`gallery-item group ${img.tilt} hover:rotate-0 transition-transform duration-500`}>
        <div class="bg-white p-3 pb-10 rounded-sm shadow-lg hover:shadow-xl transition-shadow duration-500">
          <img
            src={img.src}
            alt={img.caption}
            class="w-full h-56 md:h-64 object-cover rounded-sm"
            loading="lazy"
          />
          <p class="text-script text-base text-cocoa/60 mt-3 text-center">{img.caption}</p>
        </div>
      </div>
    ))}
  </div>
</section>
