---
const images = [
  { src: 'https://images.unsplash.com/photo-1555507036-ab1f4038808a?w=600&auto=format&fit=crop&q=85', caption: 'morning bake · sourdough', tilt: 'tilt-left' },
  { src: 'https://images.unsplash.com/photo-1513104890138-7c749659a591?w=600&auto=format&fit=crop&q=85', caption: 'twelve-inch · stone-baked', tilt: 'tilt-right' },
  { src: 'https://images.unsplash.com/photo-1509042239860-f550ce710b93?w=600&auto=format&fit=crop&q=85', caption: 'slow-pulled · espresso', tilt: '' },
  { src: 'https://images.unsplash.com/photo-1551183053-bf91a1d81141?w=600&auto=format&fit=crop&q=85', caption: 'al dente · fresh pasta', tilt: 'tilt-left' },
  { src: 'https://images.unsplash.com/photo-1587668178277-295251f900ce?w=600&auto=format&fit=crop&q=85', caption: 'the royal · falooda', tilt: 'tilt-right' },
  { src: 'https://images.unsplash.com/photo-1578985545062-69928b1d9587?w=600&auto=format&fit=crop&q=85', caption: 'baked to order · cake', tilt: '' },
];
---

<section id="gallery" class="relative py-24 md:py-40 px-6 md:px-12 bg-cream texture-paper" data-section="gallery">
  <div class="mb-16 md:mb-24">
    <span class="text-label text-sage mb-6 block">05 — Gallery</span>
    <h2 class="text-display-lg text-cocoa">The Counter</h2>
    <p class="text-script text-xl text-caramel mt-2">pulled shots, fresh bakes, and the occasional falooda</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10">
    {images.map((img) => (
      <div class={`gallery-item group ${img.tilt} hover:rotate-0 transition-transform duration-500`}>
        <div class="bg-white p-3 pb-10 rounded-sm shadow-md hover:shadow-xl transition-shadow duration-500">
          <img src={img.src} alt={img.caption} class="w-full h-56 md:h-64 object-cover rounded-sm" loading="lazy" />
          <p class="text-script text-base text-caramel/60 mt-3 text-center">{img.caption}</p>
        </div>
      </div>
    ))}
  </div>
</section>
