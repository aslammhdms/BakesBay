---
import Wheat from './illustrations/Wheat.astro';
import Steam from './illustrations/Steam.astro';

const slides = [
  {
    src: 'https://images.unsplash.com/photo-1587668178277-295251f900ce?w=1400&auto=format&fit=crop&q=85',
    alt: 'Tall layered dessert with rose syrup, ice cream and toppings',
    caption: 'the royal falooda',
  },
  {
    src: 'https://images.unsplash.com/photo-1555507036-ab1f4038808a?w=1400&auto=format&fit=crop&q=85',
    alt: 'Freshly baked artisan sourdough loaves on a dark wooden board',
    caption: 'fresh sourdough',
  },
  {
    src: 'https://images.unsplash.com/photo-1623334044303-241021148842?w=1400&auto=format&fit=crop&q=85',
    alt: 'Golden butter croissants arranged on a linen cloth',
    caption: 'butter croissants',
  },
];
---

<section id="hero" class="relative min-h-screen flex items-center overflow-hidden bg-cream texture-paper" data-section="hero">
  <div class="w-full px-6 md:px-12 py-20 md:py-0">
    <div class="flex flex-col md:flex-row items-center gap-8 md:gap-0">
      <!-- Left: Headline (60%) -->
      <div class="w-full md:w-[60%] relative z-10">
        <p class="hero-kicker text-label text-caramel/70 mb-5 md:mb-7">
          Bakes Bay &mdash; Café &middot; Bakery &middot; Kitchen
        </p>
        <div class="hero-headline">
          <div class="overflow-hidden">
            <h1 class="text-display-xl text-cocoa">Bake</h1>
          </div>
          <div class="overflow-hidden">
            <h1 class="text-display-xl text-sage">Your</h1>
          </div>
          <div class="overflow-hidden">
            <h1 class="text-display-xl text-cocoa underline-hand inline-block">Day</h1>
          </div>
        </div>
        <div class="flex items-center gap-3 mt-6">
          <p class="text-script text-xl md:text-2xl text-caramel">handcrafted in Coimbatore</p>
          <Wheat size="w-6 h-10" />
        </div>
      </div>

      <!-- Right: Hero Carousel (40%) -->
      <div class="w-full md:w-[40%] relative flex flex-col items-center">
        <div
          id="hero-carousel"
          class="hero-image relative w-72 h-96 md:w-80 md:h-[28rem] overflow-hidden rounded-2xl tilt-right shadow-2xl"
        >
          {slides.map((slide, i) => (
            <div
              class={`hero-slide absolute inset-0 ${i === 0 ? 'is-active' : ''}`}
              data-index={i}
            >
              <img
                src={slide.src}
                alt={slide.alt}
                class="hero-slide-img w-full h-full object-cover"
                loading={i === 0 ? 'eager' : 'lazy'}
                fetchpriority={i === 0 ? 'high' : 'auto'}
              />
            </div>
          ))}
          <div class="absolute bottom-4 left-0 right-0 flex justify-center gap-2 z-10">
            {slides.map((_, i) => (
              <button
                class={`hero-dot w-2 h-2 rounded-full transition-all duration-500 ${i === 0 ? 'bg-cream w-6' : 'bg-cream/40'}`}
                data-index={i}
                aria-label={`Show slide ${i + 1}`}
              ></button>
            ))}
          </div>
        </div>

        <p id="hero-caption" class="text-script text-lg text-caramel/70 mt-4 transition-opacity duration-500">
          {slides[0].caption}
        </p>

        <!-- Steam rising -->
        <div class="absolute -top-6 right-4 md:right-1/4 hidden md:block">
          <Steam size="w-10 h-16" />
        </div>
      </div>
    </div>
  </div>

  <!-- Caramel Ticker -->
  <div class="absolute bottom-0 left-0 w-full bg-caramel/15 py-3 overflow-hidden border-t border-caramel/20">
    <div class="marquee-hero flex whitespace-nowrap">
      {[0, 1, 2].map(() => (
        <span class="font-display text-lg md:text-xl italic font-semibold text-caramel/60 shrink-0 pr-8">
          FRESHLY BAKED · HANDCRAFTED · FALOODA · LASSI · MADE DAILY IN COIMBATORE ·&nbsp;
        </span>
      ))}
    </div>
  </div>

  <!-- Slide captions data for animations -->
  <script type="application/json" id="hero-captions" is:inline set:html={JSON.stringify(slides.map(s => s.caption))} />
</section>

<style>
  .marquee-hero {
    animation: marquee-hero 30s linear infinite;
    width: max-content;
  }
  @keyframes marquee-hero {
    0% { transform: translateX(0); }
    100% { transform: translateX(-33.333%); }
  }

  .hero-slide {
    opacity: 0;
    transition: opacity 1s ease;
  }
  .hero-slide.is-active {
    opacity: 1;
  }
  .hero-slide-img {
    transition: transform 7s ease-out;
    transform: scale(1.05);
  }
  .hero-slide.is-active .hero-slide-img {
    transform: scale(1.15);
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-hero { animation: none; }
    .hero-slide-img { transition: none; transform: scale(1); }
  }
</style>
