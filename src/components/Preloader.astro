---
---

<div id="preloader" class="fixed inset-0 z-50 bg-dark flex items-center justify-center" aria-hidden="true">
  <div class="relative flex flex-col items-center">
    <!-- Logo -->
    <div id="preloader-logo" class="w-28 h-28 md:w-36 md:h-36 mb-8 opacity-0">
      <img src="/logo.png" alt="" class="w-full h-full object-contain" />
    </div>

    <!-- SVG Swirl Stroke Animation -->
    <svg id="preloader-swirl" viewBox="0 0 120 120" class="absolute top-0 w-28 h-28 md:w-36 md:h-36" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="60" cy="60" r="55" stroke="#D4A574" stroke-width="1" fill="none" class="preloader-circle" />
    </svg>

    <!-- Tagline -->
    <p id="preloader-tagline" class="text-script text-2xl text-gold tracking-wide opacity-0">
      Bake Your Day
    </p>
  </div>

  <!-- Percentage Counter -->
  <span id="preloader-counter" class="absolute bottom-8 right-8 font-mono text-sm text-muted tabular-nums">
    0%
  </span>
</div>
