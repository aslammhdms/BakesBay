---

<div id="preloader" class="fixed inset-0 z-50 bg-cream texture-paper flex items-center justify-center" aria-hidden="true">
  <div class="relative flex flex-col items-center">
    <div id="preloader-logo" class="w-28 h-28 md:w-36 md:h-36 mb-5 opacity-0">
      <img src="/logo.png" alt="" class="w-full h-full object-contain" />
    </div>
    <p id="preloader-wordmark" class="font-display text-4xl md:text-5xl italic font-semibold text-cocoa tracking-tight mb-1 opacity-0">
      Bakes Bay
    </p>
    <p id="preloader-tagline" class="text-script text-xl md:text-2xl text-caramel tracking-wide opacity-0">
      Bake Your Day
    </p>
  </div>
  <span id="preloader-counter" class="absolute bottom-8 right-8 font-mono text-sm text-caramel/40 tabular-nums">
    0%
  </span>
</div>
