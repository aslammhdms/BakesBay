---
import menuData from '../data/menu.json';
import LiveBadge from './LiveBadge.astro';

const themes = menuData.themes;

const roman = ['I', 'II', 'III', 'IV', 'V', 'VI', 'VII', 'VIII', 'IX', 'X'];

const waUrl = 'https://wa.me/918438499833?text=Hi%20Bakes%20Bay%2C%20I%27d%20like%20to%20place%20an%20order';
---

<section id="menu" class="relative bg-cream texture-paper" data-section="menu">
  <!-- Intro + theme grid -->
  <div class="px-6 md:px-12 py-20 md:py-24">
    <span class="text-label text-sage mb-6 block">04 — Menu</span>
    <h2 class="text-display-lg text-cocoa mb-4">The Menu</h2>
    <p class="text-script text-xl md:text-2xl text-caramel mb-12 md:mb-16">
      From morning coffee to celebration cakes
    </p>

    <div class="grid grid-cols-2 md:grid-cols-5 gap-3 md:gap-4 max-w-6xl">
      {themes.map((theme) => (
        <a
          href={theme.link ?? `#menu-${theme.slug}`}
          class="menu-tile group relative overflow-hidden rounded-sm aspect-[4/3] shadow-md hover:shadow-xl transition-all duration-500"
          aria-label={theme.link ? `Browse ${theme.name}` : `Jump to ${theme.name}`}
        >
          <img
            src={theme.image}
            alt={theme.name}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-cocoa/85 via-cocoa/30 to-transparent"></div>
          {theme.slug === 'bakery' && (
            <div class="absolute top-2.5 right-2.5 bg-cocoa/70 backdrop-blur-sm rounded-full px-2.5 py-1">
              <LiveBadge label="LIVE" size="sm" theme="light" />
            </div>
          )}
          <div class="absolute bottom-0 left-0 right-0 p-3 md:p-4">
            <p class="font-display text-lg md:text-xl italic font-semibold text-cream leading-tight">
              {theme.name}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- Theme sections (skip ones that link out to a dedicated page) -->
  {themes.filter((t) => !t.link).map((theme, i) => (
    <div
      id={`menu-${theme.slug}`}
      class={`menu-theme px-6 md:px-12 py-16 md:py-24 ${i % 2 === 0 ? 'bg-ivory' : 'bg-cream'}`}
    >
      <div class="max-w-6xl mx-auto">
        <!-- Theme header -->
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-10 md:mb-14 border-b border-caramel/20 pb-6">
          <div>
            <span class="text-label text-caramel/60 mb-2 block">{roman[i]}</span>
            <h3 class="font-display text-4xl md:text-6xl italic font-semibold text-cocoa leading-none">
              {theme.name}
            </h3>
          </div>
          <p class="text-script text-xl md:text-2xl text-caramel md:text-right max-w-md">
            {theme.tagline}
          </p>
        </div>

        {theme.descriptive ? (
          <!-- Descriptive block (Bakery / Pastries) -->
          <div class="flex flex-col md:flex-row gap-10 md:gap-16 items-center">
            <div class="w-full md:w-[45%]">
              <div class="relative overflow-hidden rounded-sm shadow-lg aspect-[4/3]">
                <img
                  src={theme.image}
                  alt={theme.name}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
            </div>
            <div class="w-full md:w-[55%]">
              <p class="text-lg md:text-xl leading-relaxed text-espresso/80 mb-8">
                {theme.description}
              </p>
              <a
                href={waUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-6 py-3 bg-sage text-white text-label rounded-full hover:bg-forest transition-colors duration-300 shadow-md"
              >
                Order on WhatsApp →
              </a>
            </div>
          </div>
        ) : (
          <!-- Item groups (no prices) -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 md:gap-x-20 gap-y-10 md:gap-y-14">
            {theme.groups.map((group) => (
              <div class="menu-group">
                <h4 class="text-label text-sage mb-5 pb-2 border-b border-caramel/15">
                  {group.name}
                </h4>
                <ul class="space-y-2 md:space-y-3" role="list">
                  {group.items.map((item) => (
                    <li class="menu-item">
                      <span class="font-display text-base md:text-lg font-medium italic text-cocoa">
                        {item.name}
                      </span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  ))}
</section>
