---
import MenuPanel from './MenuPanel.astro';
import menuData from '../data/menu.json';

const categoryStyles = [
  { bgColor: 'bg-strawberry', textColor: 'text-forest', priceColor: 'text-cocoa' },
  { bgColor: 'bg-pistachio', textColor: 'text-forest', priceColor: 'text-forest' },
  { bgColor: 'bg-mango', textColor: 'text-cocoa', priceColor: 'text-cocoa' },
  { bgColor: 'bg-coconut', textColor: 'text-forest', priceColor: 'text-cocoa' },
];
---

<section id="menu" class="relative" data-section="menu">
  <!-- Section Intro -->
  <div class="px-6 md:px-12 py-20 bg-cream">
    <span class="text-label text-sage mb-6 block">03 — Menu</span>
    <h2 class="text-display-lg text-forest mb-4">The Menu</h2>
    <p class="text-script text-2xl text-caramel">Twenty-four ways to bake your day ✨</p>
  </div>

  <!-- Horizontal Scroll Container (desktop) / Vertical Stack (mobile) -->
  <div id="menu-scroll" class="relative">
    <div id="menu-track" class="flex flex-col md:flex-row md:flex-nowrap">
      {menuData.categories.map((category, i) => (
        <MenuPanel
          name={category.name}
          tagline={category.tagline}
          image={category.image}
          items={category.items}
          index={i}
          bgColor={categoryStyles[i % categoryStyles.length].bgColor}
          textColor={categoryStyles[i % categoryStyles.length].textColor}
          priceColor={categoryStyles[i % categoryStyles.length].priceColor}
        />
      ))}
    </div>
  </div>

  <!-- Category Navigation Dots (desktop) -->
  <div id="menu-dots" class="hidden md:flex justify-center gap-3 py-8 bg-coconut">
    {menuData.categories.map((cat, i) => (
      <button
        class="menu-dot w-2.5 h-2.5 rounded-full bg-forest/20 transition-all duration-500"
        data-index={i}
        aria-label={`Go to ${cat.name} category`}
      >
      </button>
    ))}
  </div>
</section>
