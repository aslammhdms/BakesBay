---
---

<section id="celebrations" class="relative min-h-screen flex items-center overflow-hidden" data-section="celebrations">
  <!-- Background Image -->
  <div class="absolute inset-0">
    <img
      src="https://images.unsplash.com/photo-1558301211-0d8c8ddee6ec?w=1200&q=80"
      alt="A rustic celebration spread with artisanal cakes and pastries on a wooden table"
      class="w-full h-full object-cover"
      loading="lazy"
    />
    <!-- Warm Gradient Scrim -->
    <div class="absolute inset-0 bg-gradient-to-t from-dark via-dark/75 to-dark/40"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 w-full px-6 md:px-12 py-24 md:py-40 max-w-3xl mx-auto text-center">
    <span class="text-label text-gold mb-8 block">05 — Celebrations</span>

    <h2 class="text-display-md italic mb-4">
      For the Occasions That Matter
    </h2>
    <div class="underline-hand mx-auto w-40 mb-8"></div>

    <blockquote class="mb-12">
      <p class="text-script text-3xl md:text-4xl text-gold/90 leading-snug">
        "We bake for your birthdays, anniversaries, and every quiet victory in between."
      </p>
    </blockquote>

    <p class="text-cream/70 text-base md:text-lg leading-relaxed mb-10 max-w-lg mx-auto">
      Whether it's a milestone birthday or a Tuesday that deserves celebrating, we craft bespoke
      cakes, dessert spreads, and pastry platters that turn your gathering into something unforgettable.
    </p>

    <a
      href="https://wa.me/918438459833?text=Hi%20Bakes%20Bay%2C%20I%27d%20like%20to%20enquire%20about%20celebrations"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-3 text-label text-gold hover:text-cream transition-colors duration-500 group"
    >
      Enquire on WhatsApp
      <span class="inline-block transition-transform duration-500 group-hover:translate-x-1">→</span>
    </a>
  </div>
</section>
