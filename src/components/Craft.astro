---
import Oven from './illustrations/Oven.astro';
import Wheat from './illustrations/Wheat.astro';
import Whisk from './illustrations/Whisk.astro';
import Steam from './illustrations/Steam.astro';

const pillars = [
  {
    roman: 'I',
    title: 'The Bakery',
    detail: 'sourdough, breads, laminations',
    body: 'Our bread is mixed by hand the night before and stretched into shape at first light. Laminated pastries get 27 folds and a block of cultured butter. Everything comes out of the oven before most of the city is awake.',
    icon: 'wheat',
    tilt: 'tilt-left',
  },
  {
    roman: 'II',
    title: 'The Coffee',
    detail: 'espresso, filters, cold brew',
    body: 'Single-origin beans, pulled slow on the bar, or steeped overnight for the cold brew. Our baristas remember your regular. Bring a book, stay a while.',
    icon: 'steam',
    tilt: 'tilt-right',
  },
  {
    roman: 'III',
    title: 'The Kitchen',
    detail: 'pizzas, pastas, Chinese, continental',
    body: 'Stone-baked pizzas, Alfredo and pesto pastas made fresh to order, Chinese wok classics with real heat, and café-style sandwiches that walked out of our toaster. Weekends run long here.',
    icon: 'oven',
    tilt: 'tilt-slight',
  },
  {
    roman: 'IV',
    title: 'The Desserts',
    detail: 'faloodas, shakes, cakes to order',
    body: 'The Royal Falooda is a tower of rose, vermicelli and hand-churned ice cream. Thick shakes layered by the minute. And every cake is baked to order — share the idea, we bake the rest.',
    icon: 'whisk',
    tilt: 'tilt-right',
  },
];
---

<section id="craft" class="relative py-24 md:py-40 px-6 md:px-12 bg-cream texture-paper overflow-hidden" data-section="craft">
  <div class="absolute top-10 right-10 opacity-15 hidden md:block">
    <Wheat size="w-8 h-14" />
  </div>

  <div class="mb-16 md:mb-24">
    <span class="text-label text-sage mb-6 block">03 — What We Do</span>
    <h2 class="text-display-lg text-cocoa">Four Corners</h2>
    <p class="text-script text-xl md:text-2xl text-caramel mt-3">one kitchen, four ways to walk in hungry</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 max-w-6xl mx-auto">
    {pillars.map((p) => (
      <article class={`craft-card group relative bg-ivory p-8 md:p-10 rounded-sm shadow-md hover:shadow-xl transition-shadow duration-500 ${p.tilt} hover:rotate-0`}>
        <div class="flex items-start justify-between mb-6">
          <span class="text-label text-caramel/60">{p.roman}</span>
          <div class="opacity-70 group-hover:opacity-100 transition-opacity duration-300">
            {p.icon === 'wheat' && <Wheat size="w-6 h-10" />}
            {p.icon === 'whisk' && <Whisk size="w-8 h-16" />}
            {p.icon === 'oven' && <Oven size="w-10 h-10" />}
            {p.icon === 'steam' && <Steam size="w-8 h-12" />}
          </div>
        </div>

        <h3 class="font-display text-3xl md:text-4xl italic font-semibold text-cocoa mb-3">
          {p.title}
        </h3>
        <p class="text-script text-lg text-caramel mb-6">{p.detail}</p>
        <p class="text-espresso/70 leading-relaxed">{p.body}</p>
      </article>
    ))}
  </div>
</section>
