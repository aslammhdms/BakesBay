  <path d="M16 2C9.4 2 4 7.4 4 14c0 8.5 12 24 12 24s12-15.5 12-24c0-6.6-5.4-12-12-12z"
        stroke="#C8935B" stroke-width="1.5" fill="#C8935B" fill-opacity="0.12" stroke-linejoin="round" />
