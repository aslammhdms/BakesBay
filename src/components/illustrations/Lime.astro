  <circle cx="30" cy="30" r="24" fill="#BDD4A3" />
  <circle cx="30" cy="30" r="18" fill="#FAF3E7" opacity="0.4" />
  <path d="M30 12V48" stroke="#BDD4A3" stroke-width="1" opacity="0.6" />
  <path d="M12 30H48" stroke="#BDD4A3" stroke-width="1" opacity="0.6" />
  <path d="M17 17L43 43" stroke="#BDD4A3" stroke-width="1" opacity="0.4" />
  <path d="M43 17L17 43" stroke="#BDD4A3" stroke-width="1" opacity="0.4" />
  <circle cx="30" cy="30" r="4" fill="#BDD4A3" opacity="0.8" />
</svg>
