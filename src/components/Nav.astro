---
---

<header class="fixed top-0 left-0 w-full z-40">
  <nav class="flex items-center justify-between px-6 md:px-12 py-4" aria-label="Main navigation">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 hover:scale-105 transition-transform duration-300">
      <img src="/logo.png" alt="Bakes Bay" class="h-10 md:h-12 w-auto" />
    </a>

    <!-- Menu Button -->
    <button
      id="nav-toggle"
      class="relative z-50 px-5 py-2.5 bg-sage text-white rounded-full text-label tracking-widest hover:bg-forest transition-colors duration-300 flex items-center gap-2"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="nav-overlay"
    >
      <span id="nav-toggle-text">Menu</span>
      <span class="text-xs">🍓</span>
    </button>
  </nav>
</header>
