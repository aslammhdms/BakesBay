---
---

<header class="fixed top-0 left-0 w-full z-40">
  <nav class="flex items-center justify-between px-6 md:px-12 py-5" aria-label="Main navigation">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity duration-500">
      <img src="/logo.png" alt="Bakes Bay" class="h-10 md:h-12 w-auto" />
    </a>

    <!-- Menu Button -->
    <button
      id="nav-toggle"
      class="relative z-50 text-cream text-label tracking-widest hover:text-sage transition-colors duration-500"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="nav-overlay"
    >
      <span id="nav-toggle-text">Menu</span>
    </button>
  </nav>
</header>
