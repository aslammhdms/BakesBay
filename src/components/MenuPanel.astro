---
interface MenuItem {
  name: string;
  price: number;
}

interface Props {
  name: string;
  tagline: string;
  image: string;
  items: MenuItem[];
  index: number;
  bgColor: string;
  textColor: string;
  priceColor: string;
}

const { name, tagline, image, items, index, bgColor, textColor, priceColor } = Astro.props;
---

<div class={`menu-panel shrink-0 w-screen min-h-screen flex flex-col md:flex-row items-center px-6 md:px-12 py-16 md:py-0 ${bgColor}`}>
  <!-- Left: Category Name -->
  <div class="w-full md:w-[30%] mb-8 md:mb-0 md:pl-4 overflow-hidden">
    <span class={`text-label ${priceColor} mb-4 block`}>
      {String(index + 1).padStart(2, '0')}
    </span>
    <h3 class={`font-display text-5xl md:text-7xl lg:text-8xl italic font-bold leading-none mb-4 ${textColor}`}>
      {name}
    </h3>
    <p class={`text-script text-xl ${textColor} opacity-60 max-w-xs`}>{tagline}</p>
  </div>

  <!-- Center: Hero Image -->
  <div class="w-full md:w-[35%] flex justify-center mb-8 md:mb-0">
    <div class="relative w-64 h-80 md:w-72 md:h-96 overflow-hidden rounded-3xl shadow-xl tilt-slight">
      <img
        src={image}
        alt={`Signature ${name} creation at Bakes Bay`}
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
  </div>

  <!-- Right: Items List -->
  <div class="w-full md:w-[35%]">
    <ul class="space-y-4 md:space-y-5" role="list">
      {items.map((item) => (
        <li class="menu-item group flex items-baseline justify-between gap-2">
          <span class={`font-display text-lg md:text-xl font-semibold italic ${textColor} group-hover:translate-x-2 transition-transform duration-300`}>
            {item.name}
          </span>
          <span class={`flex-1 border-b border-dotted ${textColor} opacity-20 mx-2 mb-1`}></span>
          <span class={`font-mono text-sm font-medium ${priceColor} shrink-0`}>₹{item.price}</span>
        </li>
      ))}
    </ul>
  </div>
</div>
