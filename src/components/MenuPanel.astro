---
interface MenuItem {
  name: string;
  price: number;
}

interface Props {
  name: string;
  tagline: string;
  image: string;
  items: MenuItem[];
  index: number;
}

const { name, tagline, image, items, index } = Astro.props;
---

<div class="menu-panel shrink-0 w-screen h-full flex flex-col md:flex-row items-center px-6 md:px-12 py-12 md:py-0">
  <!-- Left: Category Name -->
  <div class="w-full md:w-[30%] mb-8 md:mb-0">
    <span class="text-label text-gold mb-4 block">
      {String(index + 1).padStart(2, '0')}
    </span>
    <h3 class="font-display text-5xl md:text-7xl lg:text-8xl italic font-light leading-none mb-4">
      {name}
    </h3>
    <p class="text-script text-lg text-cream/50 max-w-xs">{tagline}</p>
  </div>

  <!-- Center: Hero Image -->
  <div class="w-full md:w-[35%] flex justify-center mb-8 md:mb-0">
    <div class="relative w-64 h-80 md:w-72 md:h-96 overflow-hidden rounded-sm">
      <img
        src={image}
        alt={`Signature ${name} creation at Bakes Bay`}
        class="w-full h-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-dark/50 to-transparent"></div>
    </div>
  </div>

  <!-- Right: Items List -->
  <div class="w-full md:w-[35%]">
    <ul class="space-y-4 md:space-y-5" role="list">
      {items.map((item) => (
        <li class="menu-item group flex items-baseline justify-between gap-2">
          <span class="font-display text-lg md:text-xl text-cream group-hover:text-gold transition-colors duration-300">
            {item.name}
          </span>
          <span class="flex-1 border-b border-dotted border-cream/15 mx-2 mb-1"></span>
          <span class="text-price shrink-0">₹{item.price}</span>
        </li>
      ))}
    </ul>
  </div>
</div>
