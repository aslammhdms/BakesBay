---
interface Props {
  class?: string;
  stroke?: string;
}
const { class: className = '', stroke = '#C8935B' } = Astro.props;
---

<svg
  class={`underline-hand-svg ${className}`}
  viewBox="0 0 200 12"
  preserveAspectRatio="none"
  aria-hidden="true"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
>
  <path
    class="underline-hand-path"
    d="M2 8C30 3 60 5 90 7C120 9 150 4 198 6"
    stroke={stroke}
    stroke-width="2"
    stroke-linecap="round"
  />
</svg>

<style>
  .underline-hand-svg {
    width: 100%;
    height: 12px;
    display: block;
  }
  .underline-hand-path {
    stroke-dasharray: 240;
    stroke-dashoffset: 240;
  }
  .underline-hand-path.is-drawn {
    stroke-dashoffset: 0;
    transition: stroke-dashoffset 1.2s ease-out;
  }
  @media (prefers-reduced-motion: reduce) {
    .underline-hand-path {
      stroke-dashoffset: 0;
      transition: none;
    }
  }
</style>
