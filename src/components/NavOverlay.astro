---
const navLinks = [
  { label: 'Home', href: '#hero', image: 'https://images.unsplash.com/photo-1509440159596-0249088772ff?w=600&auto=format&q=80' },
  { label: 'About', href: '#about', image: 'https://images.unsplash.com/photo-1517433367423-c7e5b0f35086?w=600&auto=format&q=80' },
  { label: 'Four Corners', href: '#craft', image: 'https://images.unsplash.com/photo-1555507036-ab1f4038808a?w=600&auto=format&q=80' },
  { label: 'Menu', href: '#menu', image: 'https://images.unsplash.com/photo-1513104890138-7c749659a591?w=600&auto=format&q=80' },
  { label: 'Gallery', href: '#gallery', image: 'https://images.unsplash.com/photo-1509042239860-f550ce710b93?w=600&auto=format&q=80' },
  { label: 'Celebrations', href: '#celebrations', image: 'https://images.unsplash.com/photo-1578985545062-69928b1d9587?w=600&auto=format&q=80' },
  { label: 'Journey', href: '#timeline', image: 'https://images.unsplash.com/photo-1587668178277-295251f900ce?w=600&auto=format&q=80' },
  { label: 'Visit', href: '#visit', image: 'https://images.unsplash.com/photo-1554118811-1e0d58224f24?w=600&auto=format&q=80' },
  { label: 'Contact', href: '#contact', image: 'https://images.unsplash.com/photo-1551183053-bf91a1d81141?w=600&auto=format&q=80' },
];
---

<div
  id="nav-overlay"
  class="fixed inset-0 z-40 bg-ivory texture-paper pointer-events-none opacity-0"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
>
  <div class="h-full flex flex-col justify-between px-6 md:px-12 py-24 md:py-16">
    <div class="flex-1 flex items-center">
      <div class="flex w-full">
        <ul class="flex flex-col gap-1 md:gap-2 w-full md:w-1/2" role="list">
          {navLinks.map((link, i) => (
            <li>
              <a href={link.href} class="nav-overlay-link group flex items-baseline gap-4 py-1.5" data-nav-image={link.image}>
                <span class="text-label text-caramel">{String(i + 1).padStart(2, '0')}</span>
                <span class="font-display text-3xl md:text-5xl lg:text-6xl italic font-semibold text-cocoa group-hover:text-sage transition-colors duration-300">
                  {link.label}
                </span>
              </a>
            </li>
          ))}
        </ul>
        <div class="hidden md:flex w-1/2 items-center justify-center relative">
          <div id="nav-preview-image" class="w-64 h-80 rounded-lg overflow-hidden opacity-0 scale-95 transition-all duration-500 tilt-right shadow-xl">
            <img src="" alt="" class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
    <div class="flex flex-col md:flex-row items-start md:items-end justify-between gap-6 pt-8 border-t border-cocoa/10">
      <div>
        <p class="text-label text-cocoa/40 mb-2">Get in touch</p>
        <a href="tel:+918438499833" class="text-cocoa hover:text-sage transition-colors font-medium">+91 8438 499 833</a>
      </div>
      <div class="flex gap-6">
        <a href="https://wa.me/918438499833" class="text-label text-cocoa/40 hover:text-sage transition-colors" target="_blank" rel="noopener">WhatsApp</a>
        <a href="https://instagram.com/bakesbay" class="text-label text-cocoa/40 hover:text-sage transition-colors" target="_blank" rel="noopener">Instagram</a>
      </div>
    </div>
  </div>
</div>
