---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Bakes Bay | Café, Bakery & Kitchen in Vadavalli, Coimbatore',
  description = 'Coffee, pizza, pasta, Chinese, bakery, pastries, cakes and faloodas — Bakes Bay is a multi-cuisine café and bakery with four branches across Vadavalli and Vedapatti, Coimbatore.',
} = Astro.props;

const branches = [
  { name: 'Maruthamalai Main Road', streetAddress: 'Maruthamalai Main Road, Vadavalli', postalCode: '641041' },
  { name: 'Siruvani Road Junction', streetAddress: 'Siruvani Road Junction, Vadavalli', postalCode: '641041' },
  { name: 'Grand Bei Market', streetAddress: 'Grand Bei Market, opp. JC Bus Station, Vadavalli', postalCode: '641041' },
  { name: 'Thondamuthur Main Road', streetAddress: 'Thondamuthur Main Road, near PSG School, Vedapatti', postalCode: '641007' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-image.jpg" />
    <meta property="og:url" content="https://bakesbay.com" />
    <meta property="og:site_name" content="Bakes Bay" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-image.jpg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,700;0,9..144,800;1,9..144,300;1,9..144,400;1,9..144,600;1,9..144,700;1,9..144,800&family=JetBrains+Mono:wght@300;400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Preconnect for images -->
    <link rel="preconnect" href="https://images.unsplash.com" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["Restaurant", "Bakery", "CafeOrCoffeeShop"],
      "name": "Bakes Bay",
      "description": description,
      "servesCuisine": [
        "Coffee", "Continental", "Italian", "Chinese",
        "Bakery", "Pastries", "Cakes", "Desserts"
      ],
      "address": branches.map((b) => ({
        "@type": "PostalAddress",
        "streetAddress": b.streetAddress,
        "addressLocality": "Coimbatore",
        "addressRegion": "Tamil Nadu",
        "postalCode": b.postalCode,
        "addressCountry": "IN"
      })),
      "telephone": ["+918438499833", "+919363687805"],
      "email": "bakesbay.care@gmail.com",
      "url": "https://bakesbay.com",
      "priceRange": "₹₹",
      "image": "/og-image.jpg",
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
        "opens": "11:00",
        "closes": "23:00"
      },
      "sameAs": [
        "https://instagram.com/bakesbay",
        "https://facebook.com/bakesbay",
        "https://twitter.com/bakesbay"
      ],
      "department": branches.map((b) => ({
        "@type": "Restaurant",
        "name": `Bakes Bay — ${b.name}`,
        "address": {
          "@type": "PostalAddress",
          "streetAddress": b.streetAddress,
          "addressLocality": "Coimbatore",
          "addressRegion": "Tamil Nadu",
          "postalCode": b.postalCode,
          "addressCountry": "IN"
        }
      }))
    })} />
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-sage focus:text-white focus:px-4 focus:py-2 focus:rounded">
      Skip to content
    </a>
    <slot />
  </body>
</html>
