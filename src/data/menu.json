    {
      "slug": "bakery",
      "name": "Bakery",
      "tagline": "fresh out of the oven by sunrise",
      "image": "https://images.unsplash.com/photo-1555507036-ab1f4038808a?w=800&auto=format&fit=crop&q=85",
      "descriptive": true,
      "description": "Our bread comes out of the oven before most of the city is awake. Sourdough with a crackling crust, soft milk breads, stuffed buns, and a rotating line of loaves that change with the week. Whatever makes it to the counter each morning was mixed by hand the night before — no shortcuts, no mixes."
    },
    {
      "slug": "pastries",
      "name": "Pastries",
      "tagline": "small pockets of joy",
      "image": "https://images.unsplash.com/photo-1509440159596-0249088772ff?w=800&auto=format&fit=crop&q=85",
      "descriptive": true,
      "description": "The pastry case is where we keep our small indulgences — hand-laminated croissants that shatter at the first bite, danishes with roasted fruit, éclairs, brownies, cookies, and the occasional weekend experiment from our kitchen. Pair one with a coffee and stay a while."
    },
